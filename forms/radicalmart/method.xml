<?xml version="1.0" encoding="utf-8"?>
<form addfieldprefix="Joomla\Component\RadicalMart\Administrator\Field">
	<fieldset name="settings_root" label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_PAYMENT">
		<fields name="params">
			<field name="payment_available" type="statuses"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_PAYMENT_AVAILABLE"
				   hint=" "
				   multiple="true"
				   required="true"
				   layout="joomla.form.field.list-fancy-select"/>
			<field name="paid_status" type="statuses"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_PAID_STATUS"
				   required="true"
				   layout="joomla.form.field.list-fancy-select">
				<option value="">COM_RADICALMART_STATUS_SELECT</option>
			</field>
			<field name="api_id" type="text"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_API_ID"
				   autocomplete="false"
				   required="true"/>
			<field name="api_secret" type="password"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_API_SECRET"
				   autocomplete="false"
				   required="true"/>
			<field name="url_notify" type="copy_text"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_URL_NOTIFY"
				   filter="unset"
				   readonly="true"/>
		</fields>
	</fieldset>
	<fieldset name="settings_receipt" label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT">
		<fields name="params">
			<field name="receipt" type="radio"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_LABEL"
				   class="btn-group btn-group-yesno"
				   default="0">
				<option value="1">JYES</option>
				<option value="0">JNO</option>
			</field>
			<field name="receipt_company_inn" type="text"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_COMPANY_INN"
				   showon="receipt:1"/>
			<field name="receipt_company_payment_address" type="text"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_COMPANY_PAYMENT_ADDRESS"
				   hint="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_COMPANY_PAYMENT_ADDRESS_HINT"
				   showon="receipt:1"/>
			<field name="receipt_payments_type" type="list"
				   label="PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_PAYMENTS_TYPE"
				   showon="receipt:1">
				<option value="0">PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_PAYMENTS_TYPE_0</option>
				<option value="1">PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_PAYMENTS_TYPE_1</option>
				<option value="2">PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_PAYMENTS_TYPE_2</option>
				<option value="3">PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_PAYMENTS_TYPE_3</option>
				<option value="4">PLG_RADICALMART_PAYMENT_PAYSELECTION_PARAMS_RECEIPT_PAYMENTS_TYPE_4</option>
			</field>
		</fields>
	</fieldset>
</form>